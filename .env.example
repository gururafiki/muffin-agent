# === LLM Provider (choose one) ===

# Option A: OpenRouter (access to many models with one key)
OPENAI_API_KEY=your-openrouter-key
OPENAI_SITE_URL=https://openrouter.ai/api/v1

# Option B: OpenAI direct
# OPENAI_API_KEY=your-openai-key

# Option C: Anthropic
# ANTHROPIC_API_KEY=your-anthropic-key

# === Model Settings ===
# Model. Defaults to openai/gpt-oss-120b:free (from openrouter)
# MODEL=openai/gpt-4o

# LLM provider: "openai" (also for OpenRouter) or "anthropic". Default: openai
# LLM_PROVIDER=openai

# LLM temperature. Lower = more deterministic. Default: 0.1
# TEMPERATURE=0.1

# Max evaluation criteria per agent (1-20). Default: 7
# MAX_CRITERIA=7

# === MCP Servers ===
# OpenBB MCP server URL. Default: http://127.0.0.1:8001/mcp
# Auto-configured in docker-compose.yml — only set for local CLI usage.
# OPENBB_MCP_URL=http://127.0.0.1:8001/mcp

# === Sandbox (Python code execution) ===
# OpenSandbox server address (host:port). Auto-configured in docker-compose.yml.
# For local CLI usage, start the server with:
#   docker run -d -p 8080:8080 -v /var/run/docker.sock:/var/run/docker.sock \
#     ghcr.io/alibaba/opensandbox/server:latest
# OPENSANDBOX_URL=localhost:8080

# OpenSandbox API key. Leave unset if the server runs without authentication.
# OPENSANDBOX_API_KEY=

# Docker image for sandbox containers. Override with a custom image that has
# pandas, numpy, ta-lib, etc. pre-installed to avoid downloading them on every run.
# OPENSANDBOX_IMAGE=python:3.11-slim

# === LangGraph Standalone Server (required for deployment) ===
# LANGSMITH_API_KEY=your-langsmith-api-key

# === Observability (optional) ===
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
