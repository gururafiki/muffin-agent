# === LLM Provider (choose one) ===

# Option A: OpenRouter (access to many models with one key)
OPENAI_API_KEY=your-openrouter-key
OPENAI_SITE_URL=https://openrouter.ai/api/v1

# Option B: OpenAI direct
# OPENAI_API_KEY=your-openai-key

# Option C: Anthropic
# ANTHROPIC_API_KEY=your-anthropic-key

# === Model Settings ===
# Single-model legacy default. Used by the legacy ModelConfiguration.get_llm()
# path. Defaults to openai/gpt-oss-120b (note: NO `:free` suffix — free
# OpenRouter routes have aggressive rate limits and known mid-stream chunk-merge
# bugs and must be opted into per-deployment).
# MODEL=openai/gpt-4o

# LLM provider: "openai", "anthropic", or "openrouter". Default: openai.
# Set to "openrouter" alongside OPENROUTER_API_KEY to use ChatOpenRouter
# (preferred over routing through ChatOpenAI with OPENAI_SITE_URL).
# LLM_PROVIDER=openai

# LLM temperature. Lower = more deterministic. Default: 0.1
# TEMPERATURE=0.1

# SDK-level retries for connect-time failures (network, timeouts, 5xx/429
# BEFORE any response body arrives). Mid-stream errors after a 200 OK are
# retried separately by LangChain's ModelRetryMiddleware (hardcoded defaults).
# Transient tool errors (HTTP 5xx / gateway / network) are retried separately
# by ToolRetryMiddleware (also hardcoded defaults).
# LLM_SDK_RETRIES=6

# === Per-role model chains (optional) ===
# Comma-separated lists. First entry is the primary model; the rest become
# the ModelFallbackMiddleware chain (tried after retries on the current model
# are exhausted). Each entry is instantiated through ModelConfiguration.get_llm
# so it shares LLM_PROVIDER. For mixed-provider chains, use LLM_PROVIDER=openrouter
# and list different OpenRouter model IDs.
#
# ORCHESTRATOR_MODELS=anthropic/claude-sonnet-4-6,anthropic/claude-haiku-4-5
# COLLECTOR_MODELS=anthropic/claude-haiku-4-5
# REASONER_MODELS=anthropic/claude-sonnet-4-6

# Optional cheap fast model used by ToolKnowledgeMiddleware to LLM-summarise
# tool failures into one-line lessons that get injected into the system prompt
# on subsequent turns. When unset, the middleware falls back to deterministic
# `<tool>: previous call failed — <error>` strings — still useful, just not
# LLM-distilled. Recommended: anthropic/claude-haiku-4-5.
# SUMMARISER_MODEL=anthropic/claude-haiku-4-5

# === MCP Servers ===
# OpenBB MCP server URL. Default: http://127.0.0.1:8001/mcp
# Auto-configured in docker-compose.yml — only set for local CLI usage.
# OPENBB_MCP_URL=http://127.0.0.1:8001/mcp

# === Sandbox (Python code execution) ===
# OpenSandbox server address (host:port). Auto-configured in docker-compose.yml.
# For local CLI usage, start the server with:
#   docker run -d -p 8080:8080 -v /var/run/docker.sock:/var/run/docker.sock \
#     ghcr.io/alibaba/opensandbox/server:latest
# OPENSANDBOX_URL=localhost:8080

# OpenSandbox API key. Leave unset if the server runs without authentication.
# OPENSANDBOX_API_KEY=

# Docker image for sandbox containers. Override with a custom image that has
# pandas, numpy, ta-lib, etc. pre-installed to avoid downloading them on every run.
# OPENSANDBOX_IMAGE=python:3.11-slim

# === Web Search & Crawling ===
# SearxNG search engine URL. Auto-configured in docker-compose.yml.
# For local CLI: start with `docker compose up searxng` (available on host at :8888).
# SEARXNG_URL=http://127.0.0.1:8888

# Firecrawl web scraping API URL. Auto-configured in docker-compose.yml.
# For local CLI: start with `docker compose up firecrawl-api firecrawl-redis firecrawl-playwright firecrawl-worker`
# FIRECRAWL_URL=http://127.0.0.1:3002

# Firecrawl MCP server URL. Auto-configured in docker-compose.yml.
# For host-side langgraph dev or CLI debugging: firecrawl-mcp is exposed on
# host port 3100 (host 3000 is reserved for agent-chat-ui).
# FIRECRAWL_MCP_URL=http://127.0.0.1:3100/mcp

# Firecrawl API key. Use any non-empty string when USE_DB_AUTHENTICATION=false (the default for self-hosted).
# FIRECRAWL_API_KEY=local

# SearxNG secret key — required; generate a random string for production.
# SEARXNG_SECRET_KEY=change-me

# === Research Agent ===
# Knobs for the general-purpose research agent (src/muffin_agent/agents/research/).
# Pipeline: classifier → researcher → rerank → writer. Uses Firecrawl MCP for
# web search + scrape, OpenAI-compatible embeddings for relevance rerank, and
# skills under /skills/research/ for mode + task_type guidance.

# Embedding model used by the rerank step. Default: OpenAI text-embedding-3-small.
# EMBEDDING_MODEL=text-embedding-3-small

# Optional override for the embeddings endpoint. Leave unset for OpenAI direct.
# Point at any OpenAI-compatible server (OpenRouter, vLLM, LM Studio, Ollama).
# EMBEDDING_BASE_URL=

# Optional API key for embeddings. When unset, the OpenAI SDK falls back to
# OPENAI_API_KEY — convenient for the existing OpenRouter pattern where
# OPENAI_API_KEY already holds the OpenRouter key.
# EMBEDDING_API_KEY=

# Free OpenRouter embedding model (handy for testing without OpenAI credits):
# EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=your-openrouter-key

# Rerank cosine cutoff. Chunks below this score are dropped. Default 0.5 (Vane).
# RERANK_THRESHOLD=0.5

# Max chunks kept after rerank. Default 20 (Vane).
# RERANK_TOP_K=20

# Default mode when the caller doesn't override and the classifier's hint is
# absent. One of: speed | balanced | quality. Default: balanced.
# RESEARCH_DEFAULT_MODE=balanced

# Default allowed sources when the caller doesn't supply allowed_sources.
# Comma-separated. Default: web.
# RESEARCH_DEFAULT_SOURCES=web

# Max search results requested per firecrawl_search call. Default: 8.
# MAX_SEARCH_RESULTS=8

# Per-mode LLM-call budgets for the researcher (Vane parity).
# RESEARCH_ITER_SPEED=2
# RESEARCH_ITER_BALANCED=6
# RESEARCH_ITER_QUALITY=25

# === LangGraph Standalone Server (required for deployment) ===
# LANGSMITH_API_KEY=your-langsmith-api-key

# === Observability (optional) ===
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
