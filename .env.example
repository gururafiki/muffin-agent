# === LLM Provider (choose one) ===

# Option A: OpenRouter (access to many models with one key)
OPENAI_API_KEY=your-openrouter-key
OPENAI_SITE_URL=https://openrouter.ai/api/v1

# Option B: OpenAI direct
# OPENAI_API_KEY=your-openai-key

# Option C: Anthropic
# ANTHROPIC_API_KEY=your-anthropic-key

# === Model Settings ===
# Model. Defaults to openai/gpt-oss-120b:free (from openrouter)
# MODEL=openai/gpt-4o

# LLM provider: "openai" (also for OpenRouter) or "anthropic". Default: openai
# LLM_PROVIDER=openai

# LLM temperature. Lower = more deterministic. Default: 0.1
# TEMPERATURE=0.1

# Max evaluation criteria per agent (1-20). Default: 7
# MAX_CRITERIA=7

# === Sandbox (code execution isolation) ===
# Backend for Python code execution inside the stock evaluation agent.
# "docker" — isolated sibling container (--network=none, --cap-drop=ALL, --memory=512m).
#             Requires Docker CLI in PATH and DOCKER_HOST pointing at docker-socket-proxy.
#             Auto-configured in docker-compose.yml. For local CLI: run Docker desktop and set SANDBOX_BACKEND=docker.
# "local"  — subprocess in the same virtualenv (no isolation, safe for dev only). Default.
# "none"   — disables code execution entirely.
# SANDBOX_BACKEND=local

# Docker image for the sandbox container (sandbox_backend=docker only).
# Build a custom image if TA-Lib or other native packages are needed.
# SANDBOX_DOCKER_IMAGE=python:3.12-slim

# === MCP Servers ===
# OpenBB MCP server URL. Default: http://127.0.0.1:8001/mcp
# Auto-configured in docker-compose.yml — only set for local CLI usage.
# OPENBB_MCP_URL=http://127.0.0.1:8001/mcp

# === LangGraph Standalone Server (required for deployment) ===
# LANGSMITH_API_KEY=your-langsmith-api-key

# === Observability (optional) ===
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
