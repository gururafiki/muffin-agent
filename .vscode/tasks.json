{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Docker Infra",
            "type": "shell",
            "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --wait",
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Integration Tests (offline)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest tests/integration/ -m integration -v",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Refresh Integration Fixtures (live MCP)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pytest tests/integration/test_capture_fixtures.py -m live -v",
            "dependsOn": "Start Docker Infra",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
