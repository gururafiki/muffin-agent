    "inputs": [
        {
            "id": "ticker",
            "type": "promptString",
            "description": "Stock ticker symbol",
            "default": "MSFT"
        },
        {
            "id": "query",
            "type": "promptString",
            "description": "Query to an agent",
            "default": "Get income statement and ratios."
        },
        {
            "id": "criterion",
            "type": "promptString",
            "description": "Investment criterion to evaluate",
            "default": "Does the company have strong and improving profitability?"
        },
        {
            "id": "research_query",
            "type": "promptString",
            "description": "Research question",
            "default": "Compare Postgres vs MySQL for OLTP workloads"
        },
        {
            "id": "research_mode",
            "type": "pickString",
            "description": "Research depth",
            "options": ["speed", "balanced", "quality"],
            "default": "balanced"
        },
        {
            "id": "narrative",
            "type": "promptString",
            "description": "Free-form analysis narrative (Markdown notes) for muffin decide",
            "default": "Bull thesis: durable services growth, AI device cycle. Bear thesis: China demand wobble, regulatory drag. Trades at ~22x forward P/E."
        },
        {
            "id": "analysisJsonPath",
            "type": "promptString",
            "description": "Path to upstream TickerAnalysisState JSON for muffin decide --analysis-json",
            "default": "./scratch/aapl_state.json"
        }
    ]
}