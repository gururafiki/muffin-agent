# OpenBB Provider API Keys
# Copy this file to .env and fill in the keys you have.
# See README.md in this directory for provider details and signup links.
#
# Pattern: {PROVIDER}_API_KEY (no OPENBB_ prefix)

# === Free API keys (recommended) ===
# FMP_API_KEY=
# FRED_API_KEY=
# POLYGON_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# TIINGO_TOKEN=  # TODO: validate if this api key variable works, since it doesn't end with `_API_KEY`
# NASDAQ_API_KEY=
# BLS_API_KEY=
# CONGRESS_GOV_API_KEY=
# CFTC_APP_TOKEN=
# ECONDB_API_KEY=
# BIZTOC_API_KEY=
# EIA_API_KEY=

# === Paid providers ===
# BENZINGA_API_KEY=
# INTRINIO_API_KEY=
# TRADIER_API_KEY=
# TRADIER_ACCOUNT_TYPE=sandbox
# TRADINGECONOMICS_API_KEY=
